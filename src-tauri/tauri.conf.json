{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KeyProxy",
  "version": "0.1.0",
  "identifier": "app.keyproxy",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "KeyProxy",
        "width": 360,
        "height": 480,
        "resizable": false,
        "decorations": true,
        "visible": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false
      },
      {
        "label": "settings",
        "url": "index.html#/settings",
        "title": "KeyProxy Settings",
        "width": 720,
        "height": 560,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true,
    "trayIcon": {
      "id": "main-tray",
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Credential-injecting HTTPS proxy",
    "longDescription": "KeyProxy stores API keys in the macOS Keychain and injects them into outbound HTTPS requests transparently."
  },
  "plugins": {}
}
